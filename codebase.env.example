# ------------------------------------------------------------------
# Configuracion del SEGUNDO servidor MCP (myrmion-codebase). PLANTILLA publica.
# Tu copia real vive en  config/codebase.env  (gitignored). './setup.sh' la crea.
# ------------------------------------------------------------------

# Raiz del codebase a analizar (por defecto el propio repo).
CODEBASE_ROOT=.

# Backend del grafo de codigo (mismo trio que LightRAG): filesystem | neo4j | postgres
#   filesystem -> local, grafo persistido en un JSON en config/ (ideal para empezar / tests)
#   neo4j      -> profesional, visual (Cypher en :7474); puede reutilizar la instancia de LightRAG
#   postgres   -> tablas relacionales (reutiliza la instancia Postgres de LightRAG)
CODEBASE_STORAGE=filesystem
CODEBASE_SNAPSHOT=config/codebase.json

# --- Solo si CODEBASE_STORAGE=neo4j ---
# CODEBASE_NEO4J_URI=neo4j://localhost:7687
# CODEBASE_NEO4J_USER=neo4j
# CODEBASE_NEO4J_PASSWORD=cambia-esta-clave-neo4j
# CODEBASE_NEO4J_DATABASE=codebase

# --- Solo si CODEBASE_STORAGE=postgres ---
# CODEBASE_POSTGRES_DSN=postgresql://rag:clave@localhost:5432/lightrag

# Entrypoints para afinar mandatory/dead (nombres separados por comas). Vacio = heuristica.
CODEBASE_ENTRYPOINTS=main
# Umbral para etiquetar 'reusable' (nº mínimo de módulos que referencian el símbolo).
CODEBASE_REUSABLE_MIN_MODULES=2
# Lenguajes a indexar (informativo; el parser se elige por extensión).
CODEBASE_LANGS=python,js,ts,java,csharp,vb6,vbnet,vbscript,asp
