# ------------------------------------------------------------------
# Configuracion del SERVIDOR LightRAG (no del MCP). PLANTILLA publica.
# Valores afinados para: Linux, 24 GB RAM, CPU, con VS Code + Claude Code abiertos.
# Tu copia REAL vive en  config/lightrag.env  (gitignored). './setup.sh' la crea
# desde esta plantilla y enlaza  .env -> config/lightrag.env  en la raiz.
# ------------------------------------------------------------------

# --- Servidor ---
# Por defecto solo escucha en localhost: NADA de tu red puede alcanzar el REST (:9621).
# Cambia a 0.0.0.0 SOLO si necesitas exponerlo a otra maquina; entonces la
# LIGHTRAG_API_KEY (abajo) pasa a ser obligatoria para exigir autenticacion.
HOST=127.0.0.1
PORT=9621
WORKING_DIR=./rag_storage
INPUT_DIR=./documentos
# Clave de acceso al REST. Dejala VACIA: './setup.sh' genera una aleatoria en tu copia
# config/lightrag.env y la inyecta en .mcp.json (auth ON por defecto). Deben coincidir.
LIGHTRAG_API_KEY=

# --- LLM que EXTRAE entidades/relaciones (via Ollama) ---
# 7b es el punto comodo con 24 GB y todo abierto. Si quieres un grafo mas fino,
# indexa una vez con qwen2.5:14b cerrando VS Code, y luego vuelve a 7b.
LLM_BINDING=ollama
LLM_BINDING_HOST=http://localhost:11434
LLM_MODEL=qwen2.5:7b
# CRITICO: LightRAG necesita >= 32k de contexto (Ollama da 8k por defecto).
OLLAMA_LLM_NUM_CTX=32768
# Corta la KV cache ~a la mitad (es lo que abulta a 32k). Calidad casi intacta.
OLLAMA_KV_CACHE_TYPE=q8_0

# --- Embeddings (via Ollama) ---
EMBEDDING_BINDING=ollama
EMBEDDING_BINDING_HOST=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# --- Rendimiento ---
MAX_ASYNC=2              # bajalo a 1 si notas presion de RAM
EMBEDDING_BATCH_NUM=8    # bajalo a 1 si los embeddings dan timeout en CPU

# ------------------------------------------------------------------
# ALMACENAMIENTO: elige UN perfil (las 4 vars LIGHTRAG_*_STORAGE van juntas).
# CAVEAT: el storage debe elegirse ANTES de indexar el primer documento; cambiarlo
# obliga a RE-INDEXAR desde cero. Levanta las BD con  ./db-up.sh {neo4j|postgres}.
# Valida tu config con:  python -m backends healthcheck {neo4j|postgres}
# ------------------------------------------------------------------

# PERFIL A (por defecto): ficheros locales, sin bases de datos externas.
LIGHTRAG_KV_STORAGE=JsonKVStorage
LIGHTRAG_VECTOR_STORAGE=NanoVectorDBStorage
LIGHTRAG_GRAPH_STORAGE=NetworkXStorage
LIGHTRAG_DOC_STATUS_STORAGE=JsonDocStatusStorage

# PERFIL B: Neo4j solo para el GRAFO (KV/vector/estado siguen locales).
# LIGHTRAG_KV_STORAGE=JsonKVStorage
# LIGHTRAG_VECTOR_STORAGE=NanoVectorDBStorage
# LIGHTRAG_GRAPH_STORAGE=Neo4JStorage
# LIGHTRAG_DOC_STATUS_STORAGE=JsonDocStatusStorage

# PERFIL C: PostgreSQL todo-en-uno (pgvector + Apache AGE).
# LIGHTRAG_KV_STORAGE=PGKVStorage
# LIGHTRAG_VECTOR_STORAGE=PGVectorStorage
# LIGHTRAG_GRAPH_STORAGE=PGGraphStorage
# LIGHTRAG_DOC_STATUS_STORAGE=PGDocStatusStorage

# PERFIL D (RECOMENDADO PRO): HÍBRIDO -> Postgres (KV/vector/estado) + Neo4j (grafo).
# pgvector escalable para vectores + Neo4j nativo y visual para el grafo. Requiere que
# Neo4j y Postgres se mantengan alineados: usa las tools MCP  verificar_alineacion /
# reconciliar  (saga + reconciliación auto). Levanta ambos:  ./db-up.sh pro
# LIGHTRAG_KV_STORAGE=PGKVStorage
# LIGHTRAG_VECTOR_STORAGE=PGVectorStorage
# LIGHTRAG_GRAPH_STORAGE=Neo4JStorage
# LIGHTRAG_DOC_STATUS_STORAGE=PGDocStatusStorage

# --- Credenciales de BD (descomenta según el perfil elegido) ---
# NEO4J_URI=neo4j://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=cambia-esta-clave-neo4j
# NEO4J_DATABASE=neo4j
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=rag
# POSTGRES_PASSWORD=cambia-esta-clave-postgres
# POSTGRES_DATABASE=lightrag

# ------------------------------------------------------------------
# PERFIL DE MODELO PROFESIONAL (para sistemas potentes: GPU / mucha RAM).
# Maximiza calidad de extracción y fiabilidad. Cambiar LLM_MODEL NO exige reindexar;
# cambiar EMBEDDING_MODEL/EMBEDDING_DIM SÍ (la dimensión del vector cambia).
# Descarga el modelo:  ollama pull qwen2.5:32b   (o qwen2.5:72b, qwen3:32b, ...).
# Comprueba que está:  python -m backends healthcheck  (o /api/tags de Ollama)
# ------------------------------------------------------------------
# LLM_MODEL=qwen2.5:32b
# OLLAMA_LLM_NUM_CTX=32768
# MAX_ASYNC=4
# EMBEDDING_BATCH_NUM=16
