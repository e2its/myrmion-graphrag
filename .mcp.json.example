{
  "mcpServers": {
    "graphrag-local": {
      "command": "/RUTA/ABSOLUTA/graphrag-local/venv/bin/python",
      "args": ["/RUTA/ABSOLUTA/graphrag-local/mcp_server.py"],
      "env": {
        "LIGHTRAG_BASE_URL": "http://127.0.0.1:9621",
        "LIGHTRAG_MODE": "mix",
        "LIGHTRAG_TIMEOUT": "120",
        "LIGHTRAG_API_KEY": ""
      }
    }
  }
}
